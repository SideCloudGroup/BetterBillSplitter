# 项目名称
COMPOSE_PROJECT_NAME=expense
# 网站运行端口
WEB_PORT=17985

# 数据库连接信息
MARIADB_HOST=mariadb
MARIADB_SOCKET=
MARIADB_PORT=3306
MARIADB_ROOT_PASSWORD=123456
MARIADB_DATABASE=expense
MARIADB_USER=expense
MARIADB_PASSWORD=123456

# 默认时区
APP_TIMEZONE=Asia/Shanghai

# JWT（登录 access / refresh；生产环境请更换 JWT_SECRET）
# 生成示例：openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string
# access token 有效期（秒），默认 900 = 15 分钟
JWT_ACCESS_TTL=900
# refresh token 有效期（秒），默认 2592000 = 30 天
JWT_REFRESH_TTL=2592000
# 可选：JWT iss，非空时校验 token 的 iss 声明
JWT_ISS=
# refresh Cookie 是否仅 HTTPS；本地 HTTP 部署请设为 false
JWT_REFRESH_COOKIE_SECURE=false
