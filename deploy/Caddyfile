{
	auto_https off
	admin off
	servers {
		trusted_proxies static private_ranges 0.0.0.0/0
	}
}

:80 {
	root * /var/www/html/public

	@blocked path_regexp blocked ^/(runtime|application)(/|$)
	respond @blocked 403

	@dot_ht path /.ht*
	respond @dot_ht 403

	handle /assets/* {
		root * /var/www/html/public/spa/assets
		uri strip_prefix /assets
		header Cache-Control "public, max-age=2592000, immutable"
		file_server
	}

	handle /static/* {
		root * /var/www/html/public
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	@backend path_regexp backend ^/(api|captcha)(/|$)
	handle @backend {
		@notFile not file {path}
		rewrite @notFile /index.php?s={path}&{query}

		php_fastcgi 127.0.0.1:9000 {
			root /var/www/html/public
		}
	}

	handle /spa/* {
		try_files {path} {path}/ /spa/index.html
		file_server
	}

	handle / {
		rewrite * /spa/index.html
		file_server
	}

	@php path *.php
	handle @php {
		php_fastcgi 127.0.0.1:9000 {
			root /var/www/html/public
		}
	}

	encode gzip zstd
}
